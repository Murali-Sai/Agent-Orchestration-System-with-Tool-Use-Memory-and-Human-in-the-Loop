# Required
OPENAI_API_KEY=your_openai_key_here

# Optional — enables Anthropic/Claude routing
ANTHROPIC_API_KEY=your_anthropic_key_here

# Supabase — enables persistent task storage & audit logs (optional but recommended)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional — better web search (falls back to DuckDuckGo if absent)
TAVILY_API_KEY=your_tavily_key_here

# Redis (auto-configured in Docker; change for external Redis)
REDIS_URL=redis://localhost:6379/0

# ChromaDB persistence path
CHROMA_PERSIST_DIR=./chroma_db

# Human-in-the-loop thresholds
CONFIDENCE_THRESHOLD=0.6
QUALITY_THRESHOLD=0.65
MAX_RETRIES=2

# App settings
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
UI_PORT=8501
